{
    "name": "bindbc-rpr",
    "description": "D bindings for AMD Radeon ProRender SDK (Apache 2.0). bindbc-style — dynamic loading via dlopen/LoadLibrary by default; opt-in static binding behind version=BindRPR_Static.",
    "license": "BSL-1.0",
    "authors": ["Alexander Shagarov"],

    "targetType": "library",
    "targetPath": "lib",

    "sourcePaths": ["source"],
    "importPaths": ["source"],

    "dependencies": {
        "bindbc-common": "~>1.0.5",
        "bindbc-loader": "~>1.1.5"
    },

    "preBuildCommands-osx": [
        "cd \"$PACKAGE_DIR\" && git submodule update --init --quiet extern/RadeonProRenderSDK"
    ],
    "preBuildCommands-linux": [
        "cd \"$PACKAGE_DIR\" && git submodule update --init --quiet extern/RadeonProRenderSDK"
    ],
    "preBuildCommands-windows": [
        "git -C \"%PACKAGE_DIR%\" submodule update --init --quiet extern/RadeonProRenderSDK"
    ],

    "lflags-osx":   ["-rpath", "$PACKAGE_DIR/extern/RadeonProRenderSDK/RadeonProRender/binMacOS"],
    "lflags-linux": ["-rpath", "$PACKAGE_DIR/extern/RadeonProRenderSDK/RadeonProRender/binUbuntu20"],

    "copyFiles-windows": [
        "$PACKAGE_DIR/extern/RadeonProRenderSDK/RadeonProRender/binWin64/*.dll"
    ],

    "configurations": [
        {
            "name": "dynamic",
            "comment": "Default. Runtime dlopen/LoadLibrary of libRadeonProRender64 via bindbc-loader."
        },
        {
            "name": "static",
            "comment": "Direct link against libRadeonProRender64 at compile time.",
            "versions": ["BindRPR_Static"],
            "libs": ["RadeonProRender64"]
        }
    ]
}
